# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Security
WHATSAPP_API_KEY=your-super-secret-api-key-here

# WhatsApp
WHATSAPP_SESSION_NAME=ctrlmaster-session

# Reconnection
RECONNECT_INTERVAL=5000
MAX_RECONNECT_ATTEMPTS=10

# Message Queue
MESSAGE_QUEUE_LIMIT=100

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
