{
  "name": "ctrlmaster-whatsapp-api",
  "version": "2.0.0",
  "description": "Professional WhatsApp API for CtrlMaster with queue, retry, and health monitoring",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t ctrlmaster-whatsapp .",
    "docker:run": "docker run -d --name ctrlmaster-whatsapp -p 3001:3001 --restart unless-stopped ctrlmaster-whatsapp"
  },
  "keywords": ["whatsapp", "api", "ctrlmaster"],
  "author": "CtrlMaster",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.17",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
